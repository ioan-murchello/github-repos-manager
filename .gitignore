# --- Dependencies ---
# Never upload the massive node_modules folder
node_modules/
jspm_packages/

# --- Environment Variables ---
# CRITICAL: Prevent leaking your API keys, database URLs, and secrets
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Build Outputs ---
# Production build folders
dist/
build/
out/
.next/

# --- TypeScript ---
# Prevent uploading the build info/cache
*.tsbuildinfo

# --- IDEs and Editors ---
# Visual Studio Code settings
.vscode/*
!.vscode/extensions.json
.history/
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/

# Mac system files
.DS_Store

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# --- Testing ---
coverage/

# --- Local Databases/Storage ---
# If you use SQLite locally or have a data folder
*.db
*.sqlite
data/